{
  "name": "claudear-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/main.tsx",
    "build": "bun run build.ts",
    "preview": "bun run build && bunx serve dist",
    "docs": "bun run ../scripts/docs/generate-docs.ts",
    "screenshots": "bun run ../scripts/screenshots/take-screenshots.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.0",
    "@sentry/react": "^10.39.0",
    "baseline-browser-mapping": "^2.9.19",
    "caniuse-lite": "^1.0.30001770",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "lucide-react": "^0.575.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.7.0",
    "swr": "^2.4.0",
    "tailwind-merge": "^2.2.0",
    "tw-animate-css": "^1.0.0"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.0.0",
    "@sentry/cli": "^2.40.0",
    "@tailwindcss/cli": "^4.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/bun": "latest",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.8.0"
  }
}
